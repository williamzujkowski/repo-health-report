---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div style="text-align: center; padding: 80px 24px;">
    <div style="font-size: 72px; font-weight: 800; color: var(--color-text-muted); line-height: 1; margin-bottom: 16px;">
      404
    </div>
    <h1 style="font-size: 24px; font-weight: 600; color: var(--color-text); margin: 0 0 12px;">
      Page not found
    </h1>
    <p style="font-size: 14px; color: var(--color-text-secondary); margin: 0 0 32px; max-width: 400px; margin-left: auto; margin-right: auto;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div style="display: flex; gap: 12px; justify-content: center;">
      <a href={import.meta.env.BASE_URL} style="padding: 10px 20px; background: var(--color-accent); color: white; text-decoration: none; border-radius: 6px; font-size: 14px; font-weight: 500;">
        Go to Overview
      </a>
      <a href={`${import.meta.env.BASE_URL}/leaderboard/`} style="padding: 10px 20px; border: 1px solid var(--color-border); color: var(--color-text-secondary); text-decoration: none; border-radius: 6px; font-size: 14px;">
        Browse Leaderboard
      </a>
    </div>
  </div>
</BaseLayout>
