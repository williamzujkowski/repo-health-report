---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeaderboardTable from '../components/LeaderboardTable.svelte';

import leaderboard from '../../../data/dashboard/leaderboard.json';

const base = import.meta.env.BASE_URL;
const gradedCount = leaderboard.repos.filter((r) => r.graded).length;
---

<BaseLayout title="Leaderboard" description={`Full leaderboard of ${leaderboard.repos.length.toLocaleString()} open-source repositories ranked by health score`}>
  <div style="margin-bottom: 32px;">
    <h1 style="font-size: 28px; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 8px; color: var(--color-text);">
      Leaderboard
    </h1>
    <p style="font-size: 14px; color: var(--color-text-muted); margin: 0;">
      All {leaderboard.repos.length.toLocaleString()} repositories ranked by health score.
      {gradedCount} graded, {leaderboard.repos.length - gradedCount} ungraded (documentation/mirror).
      Click column headers to sort.
    </p>
  </div>

  <LeaderboardTable client:load repos={leaderboard.repos} baseUrl={base} />
</BaseLayout>
