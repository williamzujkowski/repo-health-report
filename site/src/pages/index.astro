---
import BaseLayout from '../layouts/BaseLayout.astro';
import LollipopChart from '../components/charts/LollipopChart.astro';
import SegmentedBar from '../components/charts/SegmentedBar.astro';
import SparkBar from '../components/charts/SparkBar.astro';

import summary from '../../../data/dashboard/summary.json';
import leaderboard from '../../../data/dashboard/leaderboard.json';
import languagesData from '../../../data/dashboard/languages.json';

const base = import.meta.env.BASE_URL;

const gradedRepos = leaderboard.repos.filter((r) => r.graded);
const totalRepos = summary.totalRepos;
const codeRepos = summary.codeRepos;
const top10 = gradedRepos.slice(0, 10);

interface LangEntry {
  name: string;
  count: number;
  averageScore: number | null;
  gradeDistribution: Record<string, number>;
}
const knownLangs = (languagesData.languages as LangEntry[])
  .filter((l) => l.name !== 'unknown' && l.averageScore !== null);
const langCount = knownLangs.length;
const significantLangs = knownLangs.filter((l) => l.count >= 10);
const topLang = [...significantLangs].sort((a, b) => (b.averageScore ?? 0) - (a.averageScore ?? 0))[0];

const fPct = Math.round((summary.gradeDistribution.F / codeRepos) * 100);
const abPct = Math.round(((summary.gradeDistribution.A + summary.gradeDistribution.B) / codeRepos) * 100);

const dimensions = Object.entries(summary.dimensionAverages).sort(([, a], [, b]) => b - a);
const lowestDim = dimensions[dimensions.length - 1];
const highestDim = dimensions[0];

// Grade colors — editorial palette
const gradeColors: Record<string, string> = {
  A: 'var(--color-grade-a)',
  B: 'var(--color-grade-b)',
  C: 'var(--color-grade-c)',
  D: 'var(--color-grade-d)',
  F: 'var(--color-grade-f)',
};
const gradeOrder = ['A', 'B', 'C', 'D', 'F'] as const;

// Segmented bar data
const segmentedData = gradeOrder.map(grade => ({
  label: grade,
  value: summary.gradeDistribution[grade] ?? 0,
  color: gradeColors[grade],
}));

// Lollipop data for dimensions
function dimColor(s: number): string {
  if (s >= 70) return 'var(--color-grade-a)';
  if (s >= 55) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  return 'var(--color-grade-f)';
}
const lollipopData = dimensions.map(([dim, score]) => ({
  label: dim,
  value: score,
  color: dimColor(score),
}));

function gradeClass(grade: string): string {
  return ({ A: 'grade-A', B: 'grade-B', C: 'grade-C', D: 'grade-D', F: 'grade-F' } as Record<string, string>)[grade] ?? 'grade-NA';
}

function formatStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return String(n);
}
---

<BaseLayout title="Overview">
  <!-- Hero — large number with editorial annotation -->
  <div style="text-align: center; padding: 32px 0 48px;">
    <div style="display: flex; align-items: baseline; justify-content: center; gap: 12px; margin-bottom: 8px;">
      <span style="font-size: 72px; font-weight: 800; font-variant-numeric: tabular-nums; color: var(--color-text); line-height: 1;">
        {summary.averageScore}
      </span>
      <span style="font-size: 20px; color: var(--color-text-muted); font-weight: 500;">/100</span>
    </div>
    <h1 style="font-size: 20px; font-weight: 600; color: var(--color-text); margin: 0 0 8px;">
      Average health score
    </h1>
    <p class="chart-annotation" style="max-width: 520px; margin: 0 auto;">
      Based on automated analysis of <strong>{totalRepos.toLocaleString()} open-source repositories</strong> across
      {Object.keys(summary.dimensionAverages).length} health dimensions.
      {summary.documentationRepos} documentation-only repos are excluded from grading.
    </p>
  </div>

  <!-- Three inline stats -->
  <div style="display: flex; justify-content: center; gap: 24px; margin-bottom: 48px; flex-wrap: wrap;">
    <div style="text-align: center;">
      <div style="font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text);">{totalRepos.toLocaleString()}</div>
      <div style="font-size: 12px; color: var(--color-text-muted);">Total repos</div>
    </div>
    <div style="width: 1px; background: var(--color-border); align-self: stretch;"></div>
    <div style="text-align: center;">
      <div style="font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text);">{codeRepos.toLocaleString()}</div>
      <div style="font-size: 12px; color: var(--color-text-muted);">Graded repos</div>
    </div>
    <div style="width: 1px; background: var(--color-border); align-self: stretch;"></div>
    <div style="text-align: center;">
      <div style="font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text);">{langCount}</div>
      <div style="font-size: 12px; color: var(--color-text-muted);">Languages</div>
    </div>
  </div>

  <!-- Grade Distribution -->
  <section class="card" style="margin-bottom: 32px;">
    <h2 class="section-heading">Grade Distribution</h2>
    <p class="section-subheading">
      How {codeRepos} graded repositories score across five letter grades
    </p>
    <SegmentedBar segments={segmentedData} height={6} />
  </section>

  <!-- Dimension Averages — Lollipop Chart -->
  <section class="card" style="margin-bottom: 32px;">
    <h2 class="section-heading">Dimension Averages</h2>
    <p class="section-subheading">
      Average scores across all graded repositories
    </p>
    <LollipopChart data={lollipopData} maxValue={100} />
    <p class="chart-annotation" style="margin-top: 16px;">
      <strong>{highestDim[0]}</strong> leads at {highestDim[1]}/100, while <strong>{lowestDim[0]}</strong> lags at {lowestDim[1]}/100 — a {highestDim[1] - lowestDim[1]}-point gap.
    </p>
  </section>

  <!-- Key Insights — Callout Boxes -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px;">
    <div class="callout">
      <div class="callout-number" style="color: var(--color-grade-f);">{fPct}%</div>
      <div class="callout-text">
        of repos received an <strong>F grade</strong> — {summary.gradeDistribution.F} of {codeRepos} graded repositories
      </div>
    </div>
    <div class="callout">
      <div class="callout-number" style="color: var(--color-grade-a);">{abPct}%</div>
      <div class="callout-text">
        earned <strong>A or B</strong> — {summary.gradeDistribution.A + summary.gradeDistribution.B} repos with strong health practices
      </div>
    </div>
    <div class="callout">
      <div class="callout-number" style="color: var(--color-grade-d);">{lowestDim[1]}</div>
      <div class="callout-text">
        average <strong>{lowestDim[0]}</strong> score — the weakest dimension across all repos
      </div>
    </div>
    <div class="callout">
      <div class="callout-number" style="color: var(--color-accent);">{topLang?.averageScore}</div>
      <div class="callout-text">
        <strong>{topLang?.name}</strong> avg — highest-scoring language ({topLang?.count} repos)
      </div>
    </div>
  </div>

  <!-- Top 10 -->
  <section class="card" style="margin-bottom: 32px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
      <h2 class="section-heading" style="margin-bottom: 0;">Top 10 Repositories</h2>
      <a href={`${base}/leaderboard/`} style="font-size: 13px; color: var(--color-accent); text-decoration: none;">
        View full leaderboard &rarr;
      </a>
    </div>
    <div style="overflow-x: auto;">
      <table style="width: 100%; font-size: 13px; border-collapse: collapse;">
        <thead>
          <tr style="text-align: left; color: var(--color-text-muted); border-bottom: 2px solid var(--color-border);">
            <th style="padding: 8px 0; font-weight: 500; width: 32px;">#</th>
            <th style="padding: 8px 0; font-weight: 500;">Repository</th>
            <th style="padding: 8px 0; font-weight: 500; text-align: center;">Grade</th>
            <th style="padding: 8px 0; font-weight: 500; text-align: right;">Score</th>
            <th style="padding: 8px 0; font-weight: 500; text-align: center; width: 96px;">Health</th>
            <th style="padding: 8px 12px; font-weight: 500;">Language</th>
            <th style="padding: 8px 0; font-weight: 500; text-align: right;">Stars</th>
          </tr>
        </thead>
        <tbody>
          {top10.map((repo, i) => (
            <tr style={`border-bottom: 1px solid var(--color-border);`}>
              <td style="padding: 10px 0; color: var(--color-text-muted); font-variant-numeric: tabular-nums;">{i + 1}</td>
              <td style="padding: 10px 0;">
                <a
                  href={`${base}/repo/${repo.slug.replace('/', '--')}/`}
                  style="color: var(--color-accent); text-decoration: none;"
                >
                  {repo.slug}
                </a>
              </td>
              <td style="padding: 10px 0; text-align: center;">
                <span class:list={['grade-pill', gradeClass(repo.grade)]}>
                  {repo.grade}
                </span>
              </td>
              <td style="padding: 10px 0; text-align: right; font-variant-numeric: tabular-nums; font-weight: 600;">{repo.score}</td>
              <td style="padding: 10px 0; text-align: center;">
                <SparkBar value={repo.score} max={100} width="100%" />
              </td>
              <td style="padding: 10px 12px; color: var(--color-text-secondary);">{repo.language ?? 'unknown'}</td>
              <td style="padding: 10px 0; text-align: right; font-variant-numeric: tabular-nums; color: var(--color-text-secondary);">
                {formatStars(repo.stars)}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
