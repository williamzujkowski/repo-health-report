---
import BaseLayout from '../layouts/BaseLayout.astro';
import GradeBar from '../components/GradeBar.astro';
import ScoreBar from '../components/ScoreBar.astro';

import summary from '../../../data/dashboard/summary.json';
import leaderboard from '../../../data/dashboard/leaderboard.json';

const top10 = leaderboard.repos.filter((r) => r.graded).slice(0, 10);
const base = import.meta.env.BASE_URL;

const gradedRepos = leaderboard.repos.filter((r) => r.graded);
const withStaleIssues = gradedRepos.filter((r) => r.score < 80).length;
const staleIssuePct = Math.round((withStaleIssues / gradedRepos.length) * 100);

function gradeColor(grade: string): string {
  const map: Record<string, string> = {
    A: 'text-green-500',
    B: 'text-teal-500',
    C: 'text-yellow-500',
    D: 'text-orange-500',
    F: 'text-red-500',
  };
  return map[grade] ?? 'text-stone-400';
}

function gradeBg(grade: string): string {
  const map: Record<string, string> = {
    A: 'bg-green-500/10 text-green-500',
    B: 'bg-teal-500/10 text-teal-500',
    C: 'bg-yellow-500/10 text-yellow-500',
    D: 'bg-orange-500/10 text-orange-500',
    F: 'bg-red-500/10 text-red-500',
  };
  return map[grade] ?? 'bg-stone-500/10 text-stone-400';
}
---

<BaseLayout title="Overview">
  <!-- Hero -->
  <div class="text-center mb-16">
    <h1 class="text-5xl font-bold tracking-tight mb-3">
      {summary.totalRepos.toLocaleString()} repos analyzed
    </h1>
    <p class="text-lg text-stone-500 dark:text-stone-400 mb-6">
      Health scores for popular open-source projects across {Object.keys(summary.dimensionAverages).length} dimensions
    </p>
    <div class="inline-flex items-baseline gap-2 px-6 py-3 bg-stone-100 dark:bg-stone-900 rounded-xl">
      <span class="text-sm text-stone-500 dark:text-stone-400">Average score</span>
      <span class="text-4xl font-bold tabular-nums">{summary.averageScore}</span>
      <span class="text-sm text-stone-500 dark:text-stone-400">/ 100</span>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-8 mb-12">
    <!-- Grade Distribution -->
    <section class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6">
      <h2 class="text-lg font-semibold mb-4">Grade Distribution</h2>
      <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
        Of {summary.codeRepos} graded repositories ({summary.documentationRepos} documentation repos excluded)
      </p>
      <GradeBar distribution={summary.gradeDistribution} total={summary.codeRepos} />
    </section>

    <!-- Dimension Averages -->
    <section class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6">
      <h2 class="text-lg font-semibold mb-4">Dimension Averages</h2>
      <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
        Average scores across all graded repositories
      </p>
      <div class="flex flex-col gap-3">
        {Object.entries(summary.dimensionAverages)
          .sort(([, a], [, b]) => b - a)
          .map(([dim, score]) => (
            <ScoreBar label={dim} score={score} />
          ))}
      </div>
    </section>
  </div>

  <!-- Key Stats -->
  <section class="grid sm:grid-cols-3 gap-4 mb-12">
    <div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6 text-center">
      <div class="text-3xl font-bold text-red-500 mb-1">
        {Math.round((summary.gradeDistribution.F / summary.codeRepos) * 100)}%
      </div>
      <div class="text-sm text-stone-500 dark:text-stone-400">of repos receive an F grade</div>
    </div>
    <div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6 text-center">
      <div class="text-3xl font-bold text-orange-500 mb-1">
        {summary.dimensionAverages.Security}
      </div>
      <div class="text-sm text-stone-500 dark:text-stone-400">average Security score (lowest dimension)</div>
    </div>
    <div class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6 text-center">
      <div class="text-3xl font-bold text-green-500 mb-1">
        {Math.round((summary.gradeDistribution.A / summary.codeRepos) * 100)}%
      </div>
      <div class="text-sm text-stone-500 dark:text-stone-400">of repos earn an A grade</div>
    </div>
  </section>

  <!-- Top 10 -->
  <section class="bg-white dark:bg-stone-900 rounded-xl border border-stone-200 dark:border-stone-800 p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Top 10 Repositories</h2>
      <a href={`${base}/leaderboard/`} class="text-sm text-teal-600 dark:text-teal-400 hover:underline">
        View full leaderboard &rarr;
      </a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-stone-500 dark:text-stone-400 border-b border-stone-100 dark:border-stone-800">
            <th class="pb-2 font-medium">#</th>
            <th class="pb-2 font-medium">Repository</th>
            <th class="pb-2 font-medium text-center">Grade</th>
            <th class="pb-2 font-medium text-right">Score</th>
            <th class="pb-2 font-medium">Language</th>
            <th class="pb-2 font-medium text-right">Stars</th>
          </tr>
        </thead>
        <tbody>
          {top10.map((repo, i) => (
            <tr class="border-t border-stone-100 dark:border-stone-800/50">
              <td class="py-2 text-stone-400 tabular-nums">{i + 1}</td>
              <td class="py-2">
                <a
                  href={`https://github.com/${repo.slug}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-teal-600 dark:text-teal-400 hover:underline"
                >
                  {repo.slug}
                </a>
              </td>
              <td class="py-2 text-center">
                <span class:list={['inline-block px-2 py-0.5 rounded text-xs font-semibold', gradeBg(repo.grade)]}>
                  {repo.grade}
                </span>
              </td>
              <td class="py-2 text-right tabular-nums font-medium">{repo.score}</td>
              <td class="py-2 text-stone-600 dark:text-stone-400">{repo.language ?? 'unknown'}</td>
              <td class="py-2 text-right tabular-nums text-stone-600 dark:text-stone-400">
                {repo.stars >= 1000 ? (repo.stars / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : repo.stars}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
