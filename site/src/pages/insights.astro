---
import BaseLayout from '../layouts/BaseLayout.astro';
import LollipopChart from '../components/charts/LollipopChart.astro';

import summary from '../../../data/dashboard/summary.json';
import leaderboard from '../../../data/dashboard/leaderboard.json';
import languagesData from '../../../data/dashboard/languages.json';
import typesData from '../../../data/dashboard/types.json';

const gradedRepos = leaderboard.repos.filter((r) => r.graded);
const totalGraded = gradedRepos.length;
const totalRepos = summary.totalRepos;

const fPct = Math.round((summary.gradeDistribution.F / totalGraded) * 100);
const abPct = Math.round(((summary.gradeDistribution.A + summary.gradeDistribution.B) / totalGraded) * 100);
const aPct = Math.round((summary.gradeDistribution.A / totalGraded) * 100);

interface LangEntry {
  name: string;
  count: number;
  averageScore: number | null;
  gradeDistribution: Record<string, number>;
}

const langs = (languagesData.languages as LangEntry[])
  .filter((l) => l.averageScore !== null && l.name !== 'unknown' && l.count >= 5);
const topLangs = [...langs].sort((a, b) => (b.averageScore ?? 0) - (a.averageScore ?? 0)).slice(0, 5);
const bottomLangs = [...langs].sort((a, b) => (a.averageScore ?? 0) - (b.averageScore ?? 0)).slice(0, 5);

const dimensionEntries = Object.entries(summary.dimensionAverages) as [string, number][];
const dimensions = dimensionEntries.sort(([, a], [, b]) => a - b);
const worstDim = dimensions[0];
const bestDim = dimensions[dimensions.length - 1];
const securityScore = (summary.dimensionAverages as Record<string, number>)['Security'] ?? 0;
const docScore = (summary.dimensionAverages as Record<string, number>)['Documentation'] ?? 0;
const securityGap = docScore - securityScore;

interface TypeEntry {
  name: string;
  count: number;
  averageScore: number | null;
  graded: boolean;
}

const gradedTypes = (typesData.types as TypeEntry[])
  .filter((t) => t.graded && t.averageScore !== null)
  .sort((a, b) => (b.averageScore ?? 0) - (a.averageScore ?? 0));

const topStarRepos = [...leaderboard.repos].sort((a, b) => b.stars - a.stars).slice(0, 20);
const topStarAvg = Math.round(topStarRepos.reduce((sum, r) => sum + (r.score ?? 0), 0) / topStarRepos.length);
const typeTotal = gradedTypes.reduce((sum, t) => sum + t.count, 0);
const topType = gradedTypes[0];

function dimColor(s: number): string {
  if (s >= 70) return 'var(--color-grade-a)';
  if (s >= 55) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  return 'var(--color-grade-f)';
}

function typeColor(s: number): string {
  if (s >= 60) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  return 'var(--color-grade-f)';
}

const dimLollipop = dimensions.map(([dim, score]) => ({
  label: dim,
  value: score,
  color: dimColor(score),
}));

const typeLollipop = gradedTypes.map(t => ({
  label: t.name.charAt(0).toUpperCase() + t.name.slice(1),
  value: t.averageScore ?? 0,
  color: typeColor(t.averageScore ?? 0),
}));
---

<BaseLayout title="Insights" description="Key findings and analysis from the repository health report">
  <div style="margin-bottom: 32px;">
    <h1 style="font-size: 28px; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 8px; color: var(--color-text);">
      Insights
    </h1>
    <p style="font-size: 14px; color: var(--color-text-muted); margin: 0;">
      Key findings from analyzing {totalRepos.toLocaleString()} popular open-source repositories.
    </p>
  </div>

  <!-- Quick stats -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 40px;">
    <div class="callout" style="text-align: center;">
      <div class="callout-number" style="color: var(--color-grade-f);">{fPct}%</div>
      <div class="callout-text">F-grade rate</div>
    </div>
    <div class="callout" style="text-align: center;">
      <div class="callout-number" style="color: var(--color-text);">{summary.averageScore}</div>
      <div class="callout-text">average score</div>
    </div>
    <div class="callout" style="text-align: center;">
      <div class="callout-number" style="color: var(--color-grade-d);">{securityScore}</div>
      <div class="callout-text">security avg</div>
    </div>
    <div class="callout" style="text-align: center;">
      <div class="callout-number" style="color: var(--color-grade-a);">{topLangs[0]?.averageScore}</div>
      <div class="callout-text">{topLangs[0]?.name} avg</div>
    </div>
  </div>

  <div style="display: flex; flex-direction: column; gap: 24px;">
    <!-- Finding 1: Grade distribution -->
    <section class="card">
      <h2 style="font-size: 18px; font-weight: 600; margin: 0 0 12px; color: var(--color-text);">
        Most repos are in poor health
      </h2>
      <p class="chart-annotation" style="margin-bottom: 4px;">
        <strong style="color: var(--color-grade-f);">{fPct}%</strong> of graded repositories ({summary.gradeDistribution.F} of {totalGraded}) received an <strong>F grade</strong>,
        making it the most common grade. Only <strong style="color: var(--color-grade-a);">{aPct}%</strong> ({summary.gradeDistribution.A}) earned an A.
        The combined A+B rate is <strong>{abPct}%</strong> ({summary.gradeDistribution.A + summary.gradeDistribution.B} repos).
      </p>
      <p class="chart-annotation">
        The average score is <strong>{summary.averageScore}/100</strong>.
        Even popular, widely-used projects often lack basic health hygiene like security policies,
        CI configuration, and issue triage.
      </p>
    </section>

    <!-- Finding 2: Security -->
    <section class="card">
      <h2 style="font-size: 18px; font-weight: 600; margin: 0 0 12px; color: var(--color-text);">
        Security is the weakest dimension
      </h2>
      <p class="chart-annotation" style="margin-bottom: 16px;">
        <strong>{worstDim[0]}</strong> has the lowest average at <strong style="color: var(--color-grade-f);">{worstDim[1]}/100</strong>,
        while <strong>{bestDim[0]}</strong> leads at <strong style="color: var(--color-grade-a);">{bestDim[1]}/100</strong>.
        The <strong>{securityGap}-point gap</strong> between Documentation and Security reveals a systematic blind spot.
      </p>
      <LollipopChart data={dimLollipop} maxValue={100} />
    </section>

    <!-- Finding 3: Languages -->
    <section class="card">
      <h2 style="font-size: 18px; font-weight: 600; margin: 0 0 12px; color: var(--color-text);">
        Language choice correlates with health
      </h2>
      <p class="chart-annotation" style="margin-bottom: 16px;">
        Repositories in systems languages and modern typed languages tend to score higher.
        This likely reflects engineering culture rather than language features.
      </p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div>
          <h3 style="font-size: 12px; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 12px;">
            Highest scoring
          </h3>
          {topLangs.map((l, i) => (
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f0f0f0; font-size: 13px;">
              <span style="display: flex; align-items: center; gap: 8px;">
                <span style="color: var(--color-text-muted); width: 16px; font-variant-numeric: tabular-nums; font-size: 12px;">{i + 1}.</span>
                <span style="color: var(--color-text);">{l.name}</span>
                <span style="color: var(--color-text-muted); font-size: 11px;">({l.count})</span>
              </span>
              <span style="font-variant-numeric: tabular-nums; font-weight: 600; color: var(--color-grade-a);">{l.averageScore}</span>
            </div>
          ))}
        </div>
        <div>
          <h3 style="font-size: 12px; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 12px;">
            Lowest scoring
          </h3>
          {bottomLangs.map((l, i) => (
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f0f0f0; font-size: 13px;">
              <span style="display: flex; align-items: center; gap: 8px;">
                <span style="color: var(--color-text-muted); width: 16px; font-variant-numeric: tabular-nums; font-size: 12px;">{i + 1}.</span>
                <span style="color: var(--color-text);">{l.name}</span>
                <span style="color: var(--color-text-muted); font-size: 11px;">({l.count})</span>
              </span>
              <span style="font-variant-numeric: tabular-nums; font-weight: 600; color: var(--color-grade-f);">{l.averageScore}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Finding 4: Types -->
    <section class="card">
      <h2 style="font-size: 18px; font-weight: 600; margin: 0 0 12px; color: var(--color-text);">
        Project type matters
      </h2>
      <p class="chart-annotation" style="margin-bottom: 16px;">
        {gradedTypes.length} project types across {typeTotal} graded repos.
        {topType?.name ? `${topType.name.charAt(0).toUpperCase() + topType.name.slice(1)}` : 'Top type'} scores highest at {topType?.averageScore}/100.
      </p>
      <LollipopChart data={typeLollipop} maxValue={100} />
    </section>

    <!-- Finding 5: Stars -->
    <section class="card">
      <h2 style="font-size: 18px; font-weight: 600; margin: 0 0 12px; color: var(--color-text);">
        Stars don't guarantee health
      </h2>
      <p class="chart-annotation" style="margin-bottom: 16px;">
        The top 20 most-starred repositories average <strong>{topStarAvg}/100</strong> (overall avg: {summary.averageScore}).
        Popularity doesn't automatically translate to good engineering practices.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 8px;">
        {topStarRepos.slice(0, 8).map((r) => (
          <div style="background: var(--color-surface-alt); border: 1px solid var(--color-border); border-radius: 6px; padding: 12px; text-align: center;">
            <div style="font-size: 11px; color: var(--color-text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4px;" title={r.slug}>{r.slug.split('/')[1]}</div>
            <div style="font-size: 20px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text);">{r.score ?? '--'}</div>
            <div style="font-size: 11px; color: var(--color-text-muted); font-variant-numeric: tabular-nums;">{(r.stars / 1000).toFixed(0)}k stars</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Methodology -->
    <section style="background: var(--color-surface-alt); border: 1px solid var(--color-border); border-radius: 8px; padding: 24px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 8px; color: var(--color-text);">About this analysis</h2>
      <p style="font-size: 13px; color: var(--color-text-secondary); line-height: 1.6; margin: 0;">
        Scores are computed from publicly available repository metadata including CI configuration,
        security policies, documentation, test coverage indicators, dependency management, and issue triage.
        They reflect <em>repository health practices</em>, not code quality or project usefulness.
        Documentation-only and mirror repositories are excluded from grading.
        Data was collected on {new Date(summary.generatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}.
      </p>
    </section>
  </div>
</BaseLayout>
