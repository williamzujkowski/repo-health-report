---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LollipopChart from '../../components/charts/LollipopChart.astro';
import RadarChart from '../../components/charts/RadarChart.svelte';
import leaderboard from '../../../../data/dashboard/leaderboard.json';

export function getStaticPaths() {
  return leaderboard.repos.map((repo) => ({
    params: { slug: repo.slug.replace('/', '--') },
    props: { repo },
  }));
}

const { repo } = Astro.props;
const base = import.meta.env.BASE_URL;
const dims = repo.dimensions ?? [];
const gc = ({ A: 'grade-A', B: 'grade-B', C: 'grade-C', D: 'grade-D', F: 'grade-F' } as Record<string, string>)[repo.grade] ?? 'grade-NA';
const typeMap: Record<string, string> = { application: 'type-application', library: 'type-library', framework: 'type-framework', documentation: 'type-documentation', tool: 'type-tool' };
const tc = 'type-badge ' + (typeMap[repo.type] ?? 'type-default');
const showFindings = dims.some((d) => d.findings && d.findings.length > 0);

function dimColor(s: number): string {
  if (s >= 70) return 'var(--color-grade-a)';
  if (s >= 55) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  return 'var(--color-grade-f)';
}

const dimLollipop = dims.map(d => ({
  label: d.name,
  value: d.score,
  color: dimColor(d.score),
}));

// All data from leaderboard entry
const description = repo.description;
const topics = repo.topics ?? [];
const createdAt = repo.createdAt;
const pushedAt = repo.pushedAt;
const forks = repo.forks;
const testRatio = repo.testRatio;
const configScore = repo.configScore;
const antiPatterns = repo.antiPatterns;
const sizeCategory = repo.sizeCategory;
const languageBreakdown = repo.languages ?? [];
const analyzedAt = repo.analyzedAt;

function formatDate(iso: string | undefined): string {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

function formatShortDate(iso: string | undefined): string {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function timeAgo(iso: string | undefined): string {
  if (!iso) return '';
  const now = Date.now();
  const then = new Date(iso).getTime();
  const diffMs = now - then;
  const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (days < 1) return 'today';
  if (days === 1) return '1 day ago';
  if (days < 30) return `${days} days ago`;
  const months = Math.floor(days / 30);
  if (months === 1) return '1 month ago';
  if (months < 12) return `${months} months ago`;
  const years = Math.floor(months / 12);
  if (years === 1) return '1 year ago';
  return `${years} years ago`;
}

function testRatioLabel(ratio: number): { text: string; color: string } {
  if (ratio >= 1.0) return { text: 'excellent', color: 'var(--color-grade-a)' };
  if (ratio >= 0.5) return { text: 'good', color: 'var(--color-grade-b)' };
  if (ratio >= 0.2) return { text: 'moderate', color: 'var(--color-grade-c)' };
  return { text: 'low', color: 'var(--color-grade-f)' };
}

const sizeBadgeColors: Record<string, string> = {
  tiny: 'background: rgba(45,157,120,0.12); color: #2d9d78;',
  small: 'background: rgba(29,129,162,0.12); color: #1d81a2;',
  medium: 'background: rgba(196,160,53,0.12); color: #a68a2a;',
  large: 'background: rgba(212,118,44,0.12); color: #d4762c;',
  massive: 'background: rgba(201,70,62,0.12); color: #c9463e;',
};

// Language bar colors (rotating palette)
const langColors = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#14b8a6', '#f97316'];
---

<BaseLayout
  title={`${repo.slug} — ${repo.grade} (${repo.score}/100)`}
  description={description ?? `Health analysis of ${repo.slug}: grade ${repo.grade}, score ${repo.score}/100.`}
>
  <!-- Pagefind metadata (hidden from display) -->
  <div data-pagefind-body style="display: contents;">
    <span data-pagefind-meta="title" style="display:none">{repo.slug}</span>
    {description && <span data-pagefind-meta="description" style="display:none">{description}</span>}
    {repo.language && <span data-pagefind-filter="language" style="display:none">{repo.language}</span>}
    <span data-pagefind-filter="grade" style="display:none">{repo.grade}</span>
    <span data-pagefind-filter="type" style="display:none">{repo.type}</span>
    {topics.map((t) => <span data-pagefind-filter="topic" style="display:none">{t}</span>)}
  </div>

  <nav style="font-size: 13px; color: var(--color-text-muted); margin-bottom: 24px;">
    <a href={`${base}/leaderboard/`} style="color: var(--color-accent); text-decoration: none;">Leaderboard</a>
    <span style="margin: 0 6px;">/</span>
    <span style="color: var(--color-text);">{repo.slug}</span>
  </nav>

  <!-- Header card -->
  <div class="card" style="margin-bottom: 24px;">
    <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
      <div>
        <h1 style="font-size: 22px; font-weight: 700; margin: 0 0 4px; color: var(--color-text);">{repo.slug}</h1>
        {description && (
          <p style="font-size: 14px; color: var(--color-text-secondary); margin: 0 0 10px; max-width: 600px; line-height: 1.4;">{description}</p>
        )}
        <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 12px; font-size: 13px;">
          <span class={tc}>{repo.type}</span>
          {sizeCategory && (
            <span style={`padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; ${sizeBadgeColors[sizeCategory] ?? ''}`}>{sizeCategory}</span>
          )}
          {repo.language && <span style="color: var(--color-text-secondary);">{repo.language}</span>}
          {repo.stars !== null && repo.stars !== undefined && (
            <span style="color: var(--color-text-muted); font-variant-numeric: tabular-nums;">
              {repo.stars >= 1000 ? (repo.stars / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : repo.stars} stars
            </span>
          )}
          {forks !== undefined && (
            <span style="color: var(--color-text-muted); font-variant-numeric: tabular-nums;">
              {forks >= 1000 ? (forks / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : forks} forks
            </span>
          )}
        </div>
        {(createdAt || pushedAt) && (
          <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 6px;">
            {createdAt && <span>Created {formatShortDate(createdAt)}</span>}
            {createdAt && pushedAt && <span style="margin: 0 4px;">&middot;</span>}
            {pushedAt && <span>last pushed {timeAgo(pushedAt)}</span>}
          </div>
        )}
        {topics.length > 0 && (
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px;">
            {topics.map((t) => (
              <span style="padding: 2px 8px; border-radius: 12px; font-size: 11px; background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.2);">{t}</span>
            ))}
          </div>
        )}
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        {repo.graded && <div class:list={['grade-pill', gc]} style="font-size: 28px; padding: 8px 16px;">{repo.grade}</div>}
        <div style="text-align: center;">
          <div style="font-size: 36px; font-weight: 800; font-variant-numeric: tabular-nums; color: var(--color-text);">{repo.graded ? repo.score : '--'}</div>
          <div style="font-size: 12px; color: var(--color-text-muted);">/ 100</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Description below header -->
  {description && (
    <p style="font-size: 15px; color: var(--color-text-secondary); margin: 12px 0 0; line-height: 1.5;">
      {description}
    </p>
  )}

  <!-- Topics pills -->
  {topics.length > 0 && (
    <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px;">
      {topics.map(t => (
        <span style="font-size: 12px; padding: 2px 10px; border-radius: 12px; background: var(--color-accent); color: white; opacity: 0.8;">
          {t}
        </span>
      ))}
    </div>
  )}

  <!-- Scan date -->
  {analyzedAt && (
    <div style="font-size: 13px; color: var(--color-text-muted); margin-bottom: 16px; margin-top: 16px;">
      Last analyzed: {formatDate(analyzedAt)}
    </div>
  )}

  <!-- Metadata row -->
  {(createdAt || pushedAt || sizeCategory) && (
    <div style="display: flex; flex-wrap: wrap; gap: 16px; font-size: 13px; color: var(--color-text-secondary); margin-bottom: 24px;">
      {createdAt && <span>Created: {formatDate(createdAt)}</span>}
      {pushedAt && <span>Last pushed: {formatDate(pushedAt)}</span>}
      {sizeCategory && <span>Size: {sizeCategory}</span>}
    </div>
  )}

  <!-- Analytics cards row -->
  {(testRatio !== undefined || configScore !== undefined || antiPatterns !== undefined || languageBreakdown.length > 1) && (
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
      {testRatio !== undefined && (
        <div class="card" style="padding: 16px;">
          <div style="font-size: 11px; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Test Ratio</div>
          <div style="display: flex; align-items: baseline; gap: 8px;">
            <span style="font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text);">{testRatio.toFixed(2)}</span>
            <span style={`font-size: 13px; font-weight: 500; color: ${testRatioLabel(testRatio).color};`}>{testRatioLabel(testRatio).text}</span>
          </div>
        </div>
      )}
      {configScore !== undefined && (
        <div class="card" style="padding: 16px;">
          <div style="font-size: 11px; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Config Maturity</div>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text);">{configScore}</span>
            <span style="font-size: 12px; color: var(--color-text-muted);">/ 10</span>
          </div>
          <div style="height: 4px; background: #eee; border-radius: 9999px; overflow: hidden; margin-top: 8px;">
            <div style={`height: 100%; border-radius: 9999px; width: ${configScore * 10}%; background: ${configScore >= 7 ? 'var(--color-grade-a)' : configScore >= 4 ? 'var(--color-grade-b)' : 'var(--color-grade-f)'};`}></div>
          </div>
        </div>
      )}
      {antiPatterns !== undefined && antiPatterns > 0 && (
        <div class="card" style="padding: 16px; border-left: 3px solid var(--color-grade-f);">
          <div style="font-size: 11px; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Anti-Patterns</div>
          <div style="display: flex; align-items: baseline; gap: 8px;">
            <span style="font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-grade-f);">{antiPatterns}</span>
            <span style="font-size: 13px; color: var(--color-text-muted);">detected</span>
          </div>
        </div>
      )}
      {languageBreakdown.length > 1 && (
        <div class="card" style="padding: 16px;">
          <div style="font-size: 11px; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Languages</div>
          <div style="display: flex; height: 8px; border-radius: 4px; overflow: hidden; margin-bottom: 8px;">
            {languageBreakdown.slice(0, 8).map((lang, i) => (
              <div style={`width: ${lang.percentage}%; background: ${langColors[i % langColors.length]}; min-width: 2px;`} title={`${lang.language}: ${lang.percentage.toFixed(1)}%`}></div>
            ))}
          </div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            {languageBreakdown.slice(0, 5).map((lang, i) => (
              <span style="font-size: 11px; color: var(--color-text-secondary); display: flex; align-items: center; gap: 3px;">
                <span style={`width: 8px; height: 8px; border-radius: 50%; background: ${langColors[i % langColors.length]};`}></span>
                {lang.language} {lang.percentage.toFixed(0)}%
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  <!-- Dimension scores — radar + lollipop -->
  {dims.length > 0 && (
    <section class="card" style="margin-bottom: 24px;">
      <h2 class="section-heading">Dimension Scores</h2>
      <p class="section-subheading">Individual health dimension scores for this repository</p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: center;">
        <RadarChart
          client:visible
          dimensions={Object.fromEntries(dims.map(d => [d.name, d.score]))}
          title={repo.slug}
        />
        <div>
          <LollipopChart data={dimLollipop} maxValue={100} />
        </div>
      </div>
    </section>
  )}

  <!-- Detailed findings -->
  {showFindings && (
    <section class="card" style="margin-bottom: 24px;">
      <h2 class="section-heading">Detailed Findings</h2>
      <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
        {dims.map((dim, idx) => (
          <details open={idx === 0}>
            <summary style="cursor: pointer; font-size: 13px; font-weight: 600; color: var(--color-text); padding: 4px 0; display: flex; align-items: center; gap: 8px;">
              <span>{dim.name}</span>
              <span style={`font-size: 12px; font-weight: 500; color: ${dimColor(dim.score)};`}>{dim.score}/100</span>
            </summary>
            <div style="padding: 8px 0 0 16px;">
              {(dim.findings ?? []).map((f) => (
                <div style="display: flex; align-items: start; gap: 8px; font-size: 13px; padding: 4px 0;">
                  <span style={`font-size: 11px; color: ${f.passed ? 'var(--color-grade-a)' : 'var(--color-grade-f)'};`}>
                    {f.passed ? '\u2713' : '\u2717'}
                  </span>
                  <span style="font-weight: 500; color: var(--color-text);">{f.name}</span>
                  <span style="color: var(--color-text-muted); font-size: 12px;">{f.detail}</span>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- External links -->
  <div style="display: flex; flex-wrap: wrap; gap: 12px;">
    <a href={`https://github.com/${repo.slug}`} target="_blank" rel="noopener noreferrer" class="card" style="padding: 10px 16px; font-size: 13px; display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--color-text);">View on GitHub</a>
    <a href={`https://scorecard.dev/viewer/?uri=github.com/${repo.slug}`} target="_blank" rel="noopener noreferrer" class="card" style="padding: 10px 16px; font-size: 13px; display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--color-text);">OpenSSF Scorecard</a>
    <a href={`${base}/leaderboard/`} class="card" style="padding: 10px 16px; font-size: 13px; display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--color-text);">Back to Leaderboard</a>
  </div>
</BaseLayout>
