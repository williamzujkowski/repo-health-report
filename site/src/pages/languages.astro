---
import BaseLayout from '../layouts/BaseLayout.astro';
import LollipopChart from '../components/charts/LollipopChart.astro';
import SegmentedBar from '../components/charts/SegmentedBar.astro';
import GradeBar from '../components/GradeBar.astro';

import languagesData from '../../../data/dashboard/languages.json';

interface LangEntry {
  name: string;
  count: number;
  averageScore: number | null;
  gradeDistribution: Record<string, number>;
}

const allLanguages = languagesData.languages as LangEntry[];

const languages = allLanguages
  .filter((l) => l.averageScore !== null && l.name !== 'unknown')
  .sort((a, b) => (b.averageScore ?? 0) - (a.averageScore ?? 0));

const maxCount = Math.max(...languages.map((l) => l.count));
const highest = languages[0];
const lowest = languages[languages.length - 1];
const totalRepos = languages.reduce((sum, l) => sum + l.count, 0);
const avgScore = Math.round(languages.reduce((sum, l) => sum + (l.averageScore ?? 0) * l.count, 0) / totalRepos);

function scoreColor(s: number): string {
  if (s >= 70) return 'var(--color-grade-a)';
  if (s >= 55) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  return 'var(--color-grade-f)';
}

// LollipopChart data for scores
const scoreLollipop = languages.map(lang => ({
  label: lang.name,
  value: lang.averageScore ?? 0,
  color: scoreColor(lang.averageScore ?? 0),
}));

// LollipopChart data for repo counts
const countLollipop = [...languages]
  .sort((a, b) => b.count - a.count)
  .map(lang => ({
    label: lang.name,
    value: lang.count,
    color: 'var(--color-accent)',
  }));

const gradeColors: Record<string, string> = {
  A: 'var(--color-grade-a)',
  B: 'var(--color-grade-b)',
  C: 'var(--color-grade-c)',
  D: 'var(--color-grade-d)',
  F: 'var(--color-grade-f)',
};
---

<BaseLayout title="Languages" description="Repository health scores broken down by programming language">
  <div style="margin-bottom: 32px;">
    <h1 style="font-size: 28px; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 8px; color: var(--color-text);">
      Language Breakdown
    </h1>
    <p style="font-size: 14px; color: var(--color-text-muted); margin: 0;">
      Average health scores by primary language. {languages.length} languages across {totalRepos} repositories.
    </p>
  </div>

  <!-- Summary callouts -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 32px;">
    <div class="callout">
      <div class="callout-number" style="color: var(--color-grade-a);">{highest?.averageScore}</div>
      <div class="callout-text">
        <strong>{highest?.name}</strong> scores highest across {highest?.count} repos
      </div>
    </div>
    <div class="callout">
      <div class="callout-number" style="color: var(--color-grade-f);">{lowest?.averageScore}</div>
      <div class="callout-text">
        <strong>{lowest?.name}</strong> scores lowest across {lowest?.count} repos
      </div>
    </div>
    <div class="callout">
      <div class="callout-number" style="color: var(--color-accent);">{avgScore}</div>
      <div class="callout-text">
        Weighted average across <strong>{languages.length} languages</strong>
      </div>
    </div>
  </div>

  <!-- Score ranking — Lollipop -->
  <section class="card" style="margin-bottom: 32px;">
    <h2 class="section-heading">Average Score by Language</h2>
    <p class="section-subheading">
      Dot position shows average health score (0-100)
    </p>
    <LollipopChart data={scoreLollipop} maxValue={100} />
    <p class="chart-annotation" style="margin-top: 16px;">
      <strong>{highest?.name}</strong> scores highest at {highest?.averageScore}.
      <strong>{lowest?.name}</strong> repos score lowest among tracked languages at {lowest?.averageScore}.
    </p>
  </section>

  <!-- Repo count — Lollipop -->
  <section class="card" style="margin-bottom: 32px;">
    <h2 class="section-heading">Repository Count by Language</h2>
    <p class="section-subheading">
      Number of repositories per language in the dataset
    </p>
    <LollipopChart data={countLollipop} maxValue={maxCount} />
  </section>

  <!-- Grade distribution per language -->
  <section style="margin-bottom: 32px;">
    <h2 class="section-heading">Grade Distribution by Language</h2>
    <p class="section-subheading">Top 10 languages by repository count</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 16px;">
      {[...languages]
        .sort((a, b) => b.count - a.count)
        .slice(0, 10)
        .map((lang) => {
          const gradeOrder = ['A', 'B', 'C', 'D', 'F'] as const;
          const segments = gradeOrder.map(g => ({
            label: g,
            value: lang.gradeDistribution[g] ?? 0,
            color: gradeColors[g],
          }));
          return (
            <div class="card">
              <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px;">
                <h3 style="font-size: 14px; font-weight: 600; color: var(--color-text); margin: 0;">{lang.name}</h3>
                <span style="font-size: 12px; color: var(--color-text-muted); font-variant-numeric: tabular-nums;">
                  {lang.count} repos, avg {lang.averageScore}
                </span>
              </div>
              <SegmentedBar segments={segments} height={4} />
            </div>
          );
        })}
    </div>
  </section>
</BaseLayout>
