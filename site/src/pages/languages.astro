---
import BaseLayout from '../layouts/BaseLayout.astro';
import GradeBar from '../components/GradeBar.astro';

import languagesData from '../../../data/dashboard/languages.json';

interface LangEntry {
  name: string;
  count: number;
  averageScore: number | null;
  gradeDistribution: Record<string, number>;
}

const allLanguages = languagesData.languages as LangEntry[];

// Filter and sort by average score (highest first)
const languages = allLanguages
  .filter((l) => l.averageScore !== null && l.name !== 'unknown')
  .sort((a, b) => (b.averageScore ?? 0) - (a.averageScore ?? 0));

const maxCount = Math.max(...languages.map((l) => l.count));

// Compute compare card
const highest = languages[0];
const lowest = languages[languages.length - 1];
const totalRepos = languages.reduce((sum, l) => sum + l.count, 0);
const avgScore = Math.round(languages.reduce((sum, l) => sum + (l.averageScore ?? 0) * l.count, 0) / totalRepos);

function barColor(s: number): string {
  if (s >= 80) return 'bg-green-500';
  if (s >= 60) return 'bg-teal-500';
  if (s >= 40) return 'bg-yellow-500';
  if (s >= 20) return 'bg-orange-500';
  return 'bg-red-500';
}

function rankBadge(i: number): string {
  if (i === 0) return 'text-yellow-500';
  if (i === 1) return 'text-stone-400';
  if (i === 2) return 'text-amber-700';
  return 'text-stone-500';
}
---

<BaseLayout title="Languages" description="Repository health scores broken down by programming language">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Language Breakdown</h1>
    <p class="text-stone-500 dark:text-stone-400">
      Average health scores by primary language, sorted by score.
      {languages.length} languages across {totalRepos} repositories.
    </p>
  </div>

  <!-- Compare card -->
  <div class="grid sm:grid-cols-3 gap-4 mb-8">
    <div class="stat-card">
      <span class="text-xs text-stone-400 uppercase tracking-wider">Highest Scoring</span>
      <span class="stat-value text-green-500">{highest?.name}</span>
      <span class="stat-label">avg {highest?.averageScore}/100 across {highest?.count} repos</span>
    </div>
    <div class="stat-card">
      <span class="text-xs text-stone-400 uppercase tracking-wider">Lowest Scoring</span>
      <span class="stat-value text-red-500">{lowest?.name}</span>
      <span class="stat-label">avg {lowest?.averageScore}/100 across {lowest?.count} repos</span>
    </div>
    <div class="stat-card">
      <span class="text-xs text-stone-400 uppercase tracking-wider">Weighted Average</span>
      <span class="stat-value text-teal-500">{avgScore}</span>
      <span class="stat-label">across {languages.length} languages</span>
    </div>
  </div>

  <!-- Score ranking with colored bars -->
  <section class="card p-6 mb-8">
    <h2 class="text-lg font-semibold mb-4">Average Score by Language</h2>
    <div class="space-y-2">
      {languages.map((lang, i) => (
        <div class="flex items-center gap-3 group">
          <span class:list={['w-5 text-xs font-bold tabular-nums text-right', rankBadge(i)]}>
            {i + 1}
          </span>
          <span class="w-28 text-sm text-stone-400 shrink-0 truncate" title={lang.name}>
            {lang.name}
          </span>
          <div class="flex-1 h-6 bg-stone-100 dark:bg-stone-800 rounded overflow-hidden">
            <div
              class:list={[barColor(lang.averageScore ?? 0), 'h-full rounded animate-bar']}
              style={`width: ${lang.averageScore}%`}
            />
          </div>
          <span class="w-8 text-right text-sm font-medium tabular-nums">{lang.averageScore}</span>
          <span class="w-20 text-right text-xs text-stone-500 tabular-nums">{lang.count} repos</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Repo count by language -->
  <section class="card p-6 mb-8">
    <h2 class="text-lg font-semibold mb-4">Repository Count by Language</h2>
    <div class="space-y-2">
      {[...languages]
        .sort((a, b) => b.count - a.count)
        .map((lang) => (
          <div class="flex items-center gap-3">
            <span class="w-28 text-sm text-stone-400 shrink-0 truncate" title={lang.name}>
              {lang.name}
            </span>
            <div class="flex-1 h-5 bg-stone-100 dark:bg-stone-800 rounded overflow-hidden">
              <div
                class="h-full rounded bg-teal-500 animate-bar"
                style={`width: ${(lang.count / maxCount) * 100}%`}
              />
            </div>
            <span class="w-10 text-right text-sm tabular-nums text-stone-400">{lang.count}</span>
          </div>
        ))}
    </div>
  </section>

  <!-- Top languages grade distribution -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Grade Distribution (Top 10 Languages by Count)</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {[...languages]
        .sort((a, b) => b.count - a.count)
        .slice(0, 10)
        .map((lang) => (
          <div class="card p-4">
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="font-medium">{lang.name}</h3>
              <span class="text-sm text-stone-400 tabular-nums">{lang.count} repos, avg {lang.averageScore}</span>
            </div>
            <GradeBar distribution={lang.gradeDistribution} total={lang.count} />
          </div>
        ))}
    </div>
  </section>
</BaseLayout>
