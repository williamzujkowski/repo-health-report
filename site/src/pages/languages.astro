---
import BaseLayout from '../layouts/BaseLayout.astro';
import BarChart from '../components/charts/BarChart.astro';
import StatCard from '../components/charts/StatCard.astro';
import GradeBar from '../components/GradeBar.astro';

import languagesData from '../../../data/dashboard/languages.json';

interface LangEntry {
  name: string;
  count: number;
  averageScore: number | null;
  gradeDistribution: Record<string, number>;
}

const allLanguages = languagesData.languages as LangEntry[];

// Filter and sort by average score (highest first)
const languages = allLanguages
  .filter((l) => l.averageScore !== null && l.name !== 'unknown')
  .sort((a, b) => (b.averageScore ?? 0) - (a.averageScore ?? 0));

const maxCount = Math.max(...languages.map((l) => l.count));

// Compute compare card
const highest = languages[0];
const lowest = languages[languages.length - 1];
const totalRepos = languages.reduce((sum, l) => sum + l.count, 0);
const avgScore = Math.round(languages.reduce((sum, l) => sum + (l.averageScore ?? 0) * l.count, 0) / totalRepos);

function scoreColor(s: number): string {
  if (s >= 80) return 'var(--color-grade-a)';
  if (s >= 60) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  if (s >= 20) return 'var(--color-grade-d)';
  return 'var(--color-grade-f)';
}

// Prepare BarChart data for scores
const scoreBarData = languages.map(lang => ({
  label: lang.name,
  value: lang.averageScore ?? 0,
  color: scoreColor(lang.averageScore ?? 0),
}));

// Prepare BarChart data for repo counts (sorted by count)
const countBarData = [...languages]
  .sort((a, b) => b.count - a.count)
  .map(lang => ({
    label: lang.name,
    value: lang.count,
    color: 'var(--color-grade-b)',
  }));
---

<BaseLayout title="Languages" description="Repository health scores broken down by programming language">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Language Breakdown</h1>
    <p class="text-stone-500 dark:text-stone-400">
      Average health scores by primary language, sorted by score.
      {languages.length} languages across {totalRepos} repositories.
    </p>
  </div>

  <!-- Compare card -->
  <div class="grid sm:grid-cols-3 gap-4 mb-8">
    <StatCard value={highest?.name ?? '—'} label={`avg ${highest?.averageScore}/100 across ${highest?.count} repos`} sublabel="Highest Scoring" color="#22c55e" icon="🥇" />
    <StatCard value={lowest?.name ?? '—'} label={`avg ${lowest?.averageScore}/100 across ${lowest?.count} repos`} sublabel="Lowest Scoring" color="#ef4444" icon="🥉" />
    <StatCard value={String(avgScore)} label={`across ${languages.length} languages`} sublabel="Weighted Average" color="#14b8a6" icon="📊" />
  </div>

  <!-- Score ranking with BarChart -->
  <section class="card p-6 mb-8">
    <h2 class="text-lg font-semibold mb-4">Average Score by Language</h2>
    <BarChart data={scoreBarData} maxValue={100} height={24} />
  </section>

  <!-- Repo count by language -->
  <section class="card p-6 mb-8">
    <h2 class="text-lg font-semibold mb-4">Repository Count by Language</h2>
    <BarChart data={countBarData} maxValue={maxCount} height={22} />
  </section>

  <!-- Top languages grade distribution -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Grade Distribution (Top 10 Languages by Count)</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {[...languages]
        .sort((a, b) => b.count - a.count)
        .slice(0, 10)
        .map((lang) => (
          <div class="card p-4">
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="font-medium">{lang.name}</h3>
              <span class="text-sm text-stone-400 tabular-nums">{lang.count} repos, avg {lang.averageScore}</span>
            </div>
            <GradeBar distribution={lang.gradeDistribution} total={lang.count} />
          </div>
        ))}
    </div>
  </section>
</BaseLayout>
