---
interface Props {
  label: string;
  score: number;
  maxScore?: number;
}

const { label, score, maxScore = 100 } = Astro.props;
const pct = Math.min((score / maxScore) * 100, 100);

function barColor(s: number): string {
  if (s >= 70) return 'var(--color-grade-a)';
  if (s >= 55) return 'var(--color-grade-b)';
  if (s >= 40) return 'var(--color-grade-c)';
  return 'var(--color-grade-f)';
}
---

<div style="display: flex; align-items: center; gap: 12px;">
  <span style="width: 120px; font-size: 13px; color: var(--color-text-secondary); flex-shrink: 0;">{label}</span>
  <div style="flex: 1; height: 6px; background: #f0f0f0; border-radius: 3px; overflow: hidden;">
    <div
      style={`width: ${pct}%; height: 100%; border-radius: 3px; background: ${barColor(score)};`}
    />
  </div>
  <span style="width: 40px; text-align: right; font-size: 13px; font-weight: 600; font-variant-numeric: tabular-nums; color: var(--color-text);">{score}</span>
</div>
