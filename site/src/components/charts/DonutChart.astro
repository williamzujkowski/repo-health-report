---
interface Props {
  segments: Array<{ label: string; value: number; color: string }>;
  size?: number;
  thickness?: number;
  centerLabel?: string;
  centerValue?: string;
}
const { segments, size = 200, thickness = 24, centerLabel, centerValue } = Astro.props;
const total = segments.reduce((s, seg) => s + seg.value, 0);
const radius = (size - thickness) / 2;
const circumference = 2 * Math.PI * radius;

// Calculate stroke-dasharray/dashoffset for each segment
let offset = 0;
const arcs = segments.map(seg => {
  const pct = total > 0 ? seg.value / total : 0;
  const dashArray = `${pct * circumference} ${circumference}`;
  const dashOffset = -offset * circumference;
  offset += pct;
  return { ...seg, dashArray, dashOffset, pct };
});
---

<div class="chart-donut-wrapper">
  <div class="chart-donut-ring" style={`width: ${size}px; height: ${size}px`}>
    <svg viewBox={`0 0 ${size} ${size}`} class="chart-donut-svg">
      {arcs.map(arc => (
        <circle
          cx={size / 2} cy={size / 2} r={radius}
          fill="none"
          stroke={arc.color}
          stroke-width={thickness}
          stroke-dasharray={arc.dashArray}
          stroke-dashoffset={arc.dashOffset}
          transform={`rotate(-90 ${size/2} ${size/2})`}
        />
      ))}
    </svg>
    {centerValue && (
      <div class="chart-donut-center">
        <span class="chart-donut-value">{centerValue}</span>
        {centerLabel && <span class="chart-donut-label">{centerLabel}</span>}
      </div>
    )}
  </div>
  <div class="chart-donut-legend">
    {arcs.filter(a => a.value > 0).map(arc => (
      <div class="chart-donut-legend-item">
        <span class="chart-donut-legend-swatch" style={`background: ${arc.color}`} />
        <span class="chart-donut-legend-text">{arc.label}</span>
        <span class="chart-donut-legend-count">{arc.value}</span>
        <span class="chart-donut-legend-pct">({(arc.pct * 100).toFixed(0)}%)</span>
      </div>
    ))}
  </div>
</div>
