---
interface Segment {
  label: string;
  value: number;
  color: string;
}

interface Props {
  segments: Segment[];
  height?: number;
}

const { segments, height = 4 } = Astro.props;
const total = segments.reduce((s, seg) => s + seg.value, 0);
---

<div>
  <div class="segmented-bar" style={`height: ${height}px`}>
    {segments.map((seg) => {
      const pct = total > 0 ? (seg.value / total) * 100 : 0;
      return pct > 0 ? (
        <div style={`width: ${pct}%; background-color: ${seg.color}`} />
      ) : null;
    })}
  </div>
  <div class="flex flex-wrap gap-x-4 gap-y-1 mt-3">
    {segments.filter(s => s.value > 0).map((seg) => {
      const pct = total > 0 ? ((seg.value / total) * 100).toFixed(1) : '0';
      return (
        <div class="flex items-center gap-1.5" style="font-size: 12px;">
          <span
            style={`background: ${seg.color}; width: 10px; height: 10px; border-radius: 2px; display: inline-block; flex-shrink: 0;`}
          />
          <span style="color: var(--color-text-secondary)">{seg.label}</span>
          <span style="font-weight: 600; font-variant-numeric: tabular-nums; color: var(--color-text)">{seg.value}</span>
          <span style="color: var(--color-text-muted)">({pct}%)</span>
        </div>
      );
    })}
  </div>
</div>
