---
interface Props {
  data: Array<{ label: string; value: number; color?: string }>;
  maxValue?: number;
  height?: number;
  showValues?: boolean;
}
const { data, maxValue, height = 28, showValues = true } = Astro.props;
const max = maxValue ?? Math.max(...data.map(d => d.value), 1);
---

<div class="chart-bar-container">
  {data.map((item) => (
    <div class="chart-bar-row" style={`height: ${height}px`}>
      <span class="chart-bar-label">{item.label}</span>
      <div class="chart-bar-track">
        <div
          class="chart-bar-fill"
          style={`width: ${(item.value / max) * 100}%; background: ${item.color ?? 'var(--color-grade-b)'}`}
        />
      </div>
      {showValues && <span class="chart-bar-value">{item.value}</span>}
    </div>
  ))}
</div>
