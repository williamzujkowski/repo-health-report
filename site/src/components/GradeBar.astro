---
interface Props {
  distribution: Record<string, number>;
  total?: number;
}

const { distribution, total: totalOverride } = Astro.props;

const grades = ['A', 'B', 'C', 'D', 'F'] as const;
const colors: Record<string, string> = {
  A: 'var(--color-grade-a)',
  B: 'var(--color-grade-b)',
  C: 'var(--color-grade-c)',
  D: 'var(--color-grade-d)',
  F: 'var(--color-grade-f)',
};

const total = totalOverride ?? Object.values(distribution).reduce((a, b) => a + b, 0);
---

<div style="display: flex; flex-direction: column; gap: 8px;">
  {grades.map((grade) => {
    const count = distribution[grade] ?? 0;
    const pct = total > 0 ? (count / total) * 100 : 0;
    return (
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="width: 20px; font-size: 13px; font-weight: 600; color: var(--color-text-secondary);">{grade}</span>
        <div style="flex: 1; height: 6px; background: #f0f0f0; border-radius: 3px; overflow: hidden;">
          <div
            style={`width: ${pct}%; height: 100%; border-radius: 3px; background: ${colors[grade]};`}
          />
        </div>
        <span style="width: 64px; text-align: right; font-size: 12px; font-variant-numeric: tabular-nums; color: var(--color-text-secondary);">
          {count} ({pct.toFixed(0)}%)
        </span>
      </div>
    );
  })}
</div>
