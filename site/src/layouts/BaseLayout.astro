---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

import summary from '../../../data/dashboard/summary.json';
const { title, description = `Health scores for ${summary.totalRepos.toLocaleString()} popular open-source repositories` } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `${base}/`, label: 'Overview' },
  { href: `${base}/leaderboard/`, label: 'Leaderboard' },
  { href: `${base}/languages/`, label: 'Languages' },
  { href: `${base}/insights/`, label: 'Insights' },
  { href: `${base}/trends/`, label: 'Trends' },
  { href: `${base}/methodology/`, label: 'Methodology' },
];

function isActive(href: string): boolean {
  const normalized = currentPath.replace(/\/$/, '') || '/';
  const hrefNormalized = href.replace(/\/$/, '') || '/';
  return normalized === hrefNormalized;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Repo Health Report</title>

    <meta property="og:title" content={`${title} | Repo Health Report`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Repo Health Report" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | Repo Health Report`} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link href={`${base}/pagefind/pagefind-ui.css`} rel="stylesheet" />
  </head>
  <body style="font-family: 'Inter', system-ui, -apple-system, sans-serif; min-height: 100vh;">
    <!-- Accent bar at top -->
    <div style="height: 2px; background: var(--color-accent);"></div>

    <nav style="border-bottom: 1px solid var(--color-border); background: color-mix(in srgb, var(--color-surface) 92%, transparent); backdrop-filter: blur(8px); position: sticky; top: 0; z-index: 50;">
      <div style="max-width: 960px; margin: 0 auto; padding: 0 24px;">
        <div style="display: flex; align-items: center; justify-content: space-between; height: 52px;">
          <a href={`${base}/`} style="display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--color-text); font-size: 14px; font-weight: 600;">
            <span style="color: var(--color-accent); font-size: 16px;">&#9632;</span>
            Repo Health Report
          </a>

          <!-- Desktop nav -->
          <div class="hidden sm:flex" style="align-items: center; gap: 2px;">
            {navLinks.map((link) => (
              <a
                href={link.href}
                style={`padding: 6px 14px; font-size: 13px; border-radius: 4px; text-decoration: none; ${
                  isActive(link.href)
                    ? `background: var(--color-accent-light); color: var(--color-accent); font-weight: 500;`
                    : `color: var(--color-text-secondary);`
                }`}
              >
                {link.label}
              </a>
            ))}
            <button
              id="theme-toggle"
              aria-label="Toggle dark mode"
              style="margin-left: 8px; padding: 5px 8px; font-size: 16px; line-height: 1; background: none; border: 1px solid var(--color-border); border-radius: 4px; cursor: pointer; color: var(--color-text-secondary);"
            >
              <span id="theme-icon">☀️</span>
            </button>
            <button
              id="search-trigger"
              aria-label="Search repositories (press /)"
              title="Search (press /)"
              style="margin-left: 4px; padding: 5px 10px; font-size: 13px; background: none; border: 1px solid var(--color-border); border-radius: 4px; cursor: pointer; color: var(--color-text-secondary); display: flex; align-items: center; gap: 5px;"
            >
              <svg style="width: 13px; height: 13px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              Search
              <kbd style="font-size: 10px; padding: 1px 4px; border: 1px solid var(--color-border); border-radius: 3px; opacity: 0.6;">/</kbd>
            </button>
          </div>

          <!-- Mobile hamburger -->
          <button
            class="sm:hidden"
            style="padding: 8px; color: var(--color-text-secondary); background: none; border: none; cursor: pointer;"
            onclick="document.querySelector('.mobile-nav-wrapper')?.classList.toggle('mobile-menu-open')"
            aria-label="Toggle navigation"
          >
            <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div class="mobile-nav-wrapper sm:hidden">
        <div class="mobile-menu" style="border-top: 1px solid var(--color-border); background: var(--color-surface);">
          <div style="padding: 12px 24px;">
            {navLinks.map((link) => (
              <a
                href={link.href}
                style={`display: block; padding: 8px 12px; font-size: 13px; border-radius: 4px; text-decoration: none; ${
                  isActive(link.href)
                    ? `background: var(--color-accent-light); color: var(--color-accent); font-weight: 500;`
                    : `color: var(--color-text-secondary);`
                }`}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>

    <main style="max-width: 960px; margin: 0 auto; padding: 40px 24px;">
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--color-border); padding: 32px 0; margin-top: 64px;">
      <div style="max-width: 960px; margin: 0 auto; padding: 0 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
        <p style="font-size: 12px; color: var(--color-text-muted); max-width: 480px; margin: 0;">
          Generated from automated analysis of popular open-source repositories.
          Scores reflect repository health practices, not code quality.
        </p>
        <div style="display: flex; align-items: center; gap: 16px; font-size: 12px; color: var(--color-text-muted);">
          <a
            href="https://github.com/williamzujkowski/repo-health-report"
            target="_blank"
            rel="noopener noreferrer"
            style="color: var(--color-text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px;"
          >
            <svg style="width: 14px; height: 14px;" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
            </svg>
            Source
          </a>
          <span>Built with Astro</span>
        </div>
      </div>
    </footer>
    <!-- Pagefind search modal -->
    <div
      id="search-modal"
      style="display:none; position:fixed; inset:0; z-index:100; background: rgba(0,0,0,0.5); align-items: flex-start; justify-content: center;"
      role="dialog"
      aria-modal="true"
      aria-label="Search"
    >
      <div style="max-width:640px; width: 90%; margin: 80px auto 0; background: var(--color-surface); border-radius: 12px; padding: 24px; box-shadow: 0 25px 50px rgba(0,0,0,0.25);">
        <div id="search-container"></div>
      </div>
    </div>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const icon = document.getElementById('theme-icon');
      const stored = localStorage.getItem('theme');

      // Apply stored preference or follow OS
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        if (icon) icon.textContent = '🌙';
      }

      if (toggle && icon) {
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          icon.textContent = isDark ? '🌙' : '☀️';
        });
      }

      // Pagefind search
      const searchTrigger = document.getElementById('search-trigger');
      const searchModal = document.getElementById('search-modal');
      const searchContainer = document.getElementById('search-container');
      let searchLoaded = false;

      async function openSearch() {
        if (!searchModal) return;
        searchModal.style.display = 'flex';
        if (!searchLoaded) {
          try {
            // Construct URL dynamically so Vite/Rollup does not attempt to bundle
            // the pagefind module (it is generated after build by pagefind CLI).
            const pagefindUrl = '/repo-health-report/pagefind/pagefind.js';
            // @ts-ignore — pagefind is generated at build time, not resolvable at compile time
            const pagefind = await import(/* @vite-ignore */ pagefindUrl);
            await pagefind.init();
            // @ts-ignore
            new pagefind.PagefindUI({ element: searchContainer, showSubResults: true });
            searchLoaded = true;
          } catch (e) {
            if (searchContainer) {
              searchContainer.innerHTML = '<p style="color: var(--color-text-muted); font-size: 13px; text-align: center; padding: 16px;">Search index not available. Run <code>pnpm build</code> first.</p>';
            }
          }
        }
        // Focus search input
        setTimeout(() => {
          const input = searchContainer?.querySelector('input');
          if (input) (input as HTMLInputElement).focus();
        }, 100);
      }

      function closeSearch() {
        if (searchModal) searchModal.style.display = 'none';
      }

      searchTrigger?.addEventListener('click', openSearch);

      searchModal?.addEventListener('click', (e) => {
        if (e.target === searchModal) closeSearch();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeSearch();
        }
        if (e.key === '/' && !(e.target as Element).matches('input,textarea,select,[contenteditable]')) {
          e.preventDefault();
          openSearch();
        }
      });
    </script>
  </body>
</html>
