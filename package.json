{
  "name": "repo-health-report",
  "version": "2.0.0",
  "description": "Analyze GitHub repository health across 6 dimensions with pluggable detectors",
  "type": "module",
  "bin": {
    "repo-health-report": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "SCORING.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "node --experimental-test-module-mocks --test tests/*.test.js",
    "batch": "node dist/batch.js",
    "aggregate": "node dist/aggregate.js",
    "debrief": "node dist/debrief.js",
    "export": "node dist/export.js",
    "org-audit": "node dist/org-audit.js",
    "prepublishOnly": "npx tsc"
  },
  "keywords": [
    "github",
    "repository",
    "health",
    "security",
    "scorecard",
    "opensf",
    "analysis",
    "cli",
    "devops",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/williamzujkowski/repo-health-report.git"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "William Zujkowski",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
